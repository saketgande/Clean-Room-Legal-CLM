APP_NAME="Clean Room Legal CLM"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://legal_clm:legal_clm@postgres:5432/legal_clm
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/data/contracts

SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
SETUP_TOKEN=local-setup-token

ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,text/plain,image/png,image/jpeg
MAX_UPLOAD_SIZE_BYTES=52428800

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
MOCK_CLAUDE=true
AI_STORE_RAW_OUTPUTS=true
AI_MAX_TOOL_ITERATIONS=8
AI_DEFAULT_TEMPERATURE=0

REDUCTO_API_KEY=
MOCK_REDUCTO=true

RESEND_API_KEY=
RESEND_FROM_EMAIL=legal-clm@example.com
MOCK_RESEND=true

DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY_PATH=
MOCK_DOCUSIGN=true

ALLOW_DEV_RESET=false
DEV_SEED_ADMIN_EMAIL=admin@example.com
DEV_SEED_ADMIN_PASSWORD=local-dev-password
