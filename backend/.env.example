APP_NAME="Clean Room Legal CLM"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://legal_clm:legal_clm@postgres:5432/legal_clm
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/data/contracts

SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
SETUP_TOKEN=local-setup-token

ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,text/plain,image/png,image/jpeg
MAX_UPLOAD_SIZE_BYTES=52428800

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest
MOCK_CLAUDE=true
AI_STORE_RAW_OUTPUTS=true
AI_MAX_TOOL_ITERATIONS=8
AI_DEFAULT_TEMPERATURE=0

REDUCTO_API_KEY=
MOCK_REDUCTO=true

RESEND_API_KEY=
RESEND_FROM_EMAIL=legal-clm@example.com
MOCK_RESEND=true

DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY_PATH=
DOCUSIGN_OAUTH_BASE_URL=https://account-d.docusign.com
DOCUSIGN_REST_BASE_URL=https://demo.docusign.net/restapi
MOCK_DOCUSIGN=true

ALLOW_DEV_RESET=false
DEV_SEED_ADMIN_EMAIL=admin@example.com
DEV_SEED_ADMIN_PASSWORD=local-dev-password

# --- CORS / hosts ---
# Comma-separated; production must NOT use '*'.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID,X-CSRF-Token
ALLOWED_HOSTS=*
FORCE_HTTPS=false

# --- SQLAlchemy connection pool ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30

# --- Refresh token cookie (HttpOnly) ---
REFRESH_COOKIE_NAME=aegis_refresh
REFRESH_COOKIE_PATH=/api/v1/auth
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SECURE=false
# Legacy clients can still read refresh_token from the JSON body when this is on.
# MUST be false in production.
EXPOSE_REFRESH_TOKEN_IN_BODY=true

# --- Rate limits ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=30/minute
RATE_LIMIT_PASSWORD_RESET=5/minute
RATE_LIMIT_INVITATION_ACCEPT=5/minute

# --- Dev affordances; MUST be false in production ---
EXPOSE_PASSWORD_RESET_TOKEN_IN_RESPONSE=false

# --- Request log redaction ---
REQUEST_LOG_REDACT_QUERY=true
REQUEST_LOG_SENSITIVE_QUERY_KEYS=token,passcode,refresh_token,access_token,api_key,setup_token

# --- Claude resiliency ---
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_INITIAL_BACKOFF_SECONDS=1.0
CLAUDE_RETRY_MAX_BACKOFF_SECONDS=30.0

# --- Upload safety ---
UPLOAD_STREAM_CHUNK_BYTES=1048576
PDF_MAX_EXTRACTED_TEXT_BYTES=8388608
